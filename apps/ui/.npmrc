# Local pnpm config for @dojocho/ui.
#
# Disable the minimum-release-age guard for this package. We intentionally
# pull recent releases (Hono, TanStack Start, Nitro, @a2a-js/sdk) to track
# upstream; the user's global pnpm policy of "no packages younger than N
# days" would block those.
minimum-release-age=0
