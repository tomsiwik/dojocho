{
  "name": "dojocho",
  "version": "1.0.1",
  "description": "Installable coding dojos that turn your AI agent into a sensei.",
  "keywords": [
    "cli",
    "dojo",
    "kata",
    "ai-agent",
    "claude",
    "claude-code",
    "coding-practice",
    "pair-programming"
  ],
  "license": "MIT",
  "author": "Tomas Sivicki <tomas.sivicki@gmail.com>",
  "homepage": "https://dojocho.ai",
  "bugs": {
    "url": "https://github.com/tomsiwik/dojocho/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tomsiwik/dojocho.git",
    "directory": "packages/cli"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "dojo": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@dojocho/config": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
