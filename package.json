{
  "name": "dojocho",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build": "turbo build",
    "e2e:up": "docker compose up -d --wait --build",
    "e2e:down": "docker compose down -v --remove-orphans",
    "e2e:logs": "docker compose logs -f dojocho-e2e",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "turbo": "^2.9.18",
    "vitest": "^4.1.9",
    "youch": "^4.1.1"
  }
}
