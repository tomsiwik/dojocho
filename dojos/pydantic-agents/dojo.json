{
  "$schema": "https://dojocho.ai/schema/v1/dojo.json",
  "name": "@dojocho/pydantic-agents",
  "version": "0.0.1",
  "description": "Learn Pydantic models, validation, and pydantic-ai agents through hands-on katas",

  "runner": { "adapter": "exit-code" },
  "test": "uv run pytest {template} -v",
  "katas": [
    { "template": "katas/001-basic-model/solution.py", "test": "uv run pytest katas/001-basic-model/test_solution.py -v" },
    { "template": "katas/002-validation/solution.py", "test": "uv run pytest katas/002-validation/test_solution.py -v" },
    { "template": "katas/003-simple-agent/solution.py", "test": "uv run pytest katas/003-simple-agent/test_solution.py -v" }
  ]
}
